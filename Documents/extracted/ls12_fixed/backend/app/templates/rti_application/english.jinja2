{# RTI Application Template - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTI Application</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', 'Calibri', sans-serif;
            line-height: 1.6;
            color: #333;
            background: white;
        }
        
        .document {
            max-width: 8.5in;
            height: 11in;
            margin: 0 auto;
            padding: 0.75in;
            background: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        
        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 12px;
            margin-bottom: 20px;
        }
        
        .header h1 {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .header h2 {
            font-size: 14px;
            font-weight: bold;
        }
        
        .section {
            margin: 15px 0;
        }
        
        .section-title {
            font-weight: bold;
            background-color: #f0f0f0;
            padding: 6px 8px;
            margin-bottom: 8px;
            font-size: 12px;
        }
        
        .field-row {
            margin: 8px 0;
            font-size: 11px;
            line-height: 1.5;
        }
        
        .label {
            font-weight: bold;
            display: inline-block;
            width: 120px;
        }
        
        .value {
            display: inline-block;
            max-width: 5in;
            word-wrap: break-word;
        }
        
        .signature-area {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
        }
        
        .signature-box {
            width: 40%;
            text-align: center;
        }
        
        .signature-line {
            border-top: 1px solid #000;
            width: 100%;
            padding-top: 5px;
            font-size: 11px;
        }
        
        .disclaimer {
            font-size: 9px;
            border: 1px solid #999;
            padding: 8px;
            background-color: #fffacd;
            margin-top: 20px;
            line-height: 1.4;
        }
        
        p {
            font-size: 11px;
            margin: 5px 0;
        }
    </style>
</head>
<body>

<div class="document">
    
    <div class="header">
        <h1>RIGHT TO INFORMATION ACT, 2005</h1>
        <h2>APPLICATION FOR INFORMATION</h2>
    </div>
    
    <div class="section">
        <div class="section-title">TO:</div>
        <p>
            <span class="label">Public Authority:</span>
            <span class="value">{{ public_authority }}</span>
        </p>
    </div>
    
    <div class="section">
        <div class="section-title">FROM (APPLICANT DETAILS):</div>
        <div class="field-row">
            <span class="label">Name:</span>
            <span class="value">{{ applicant_name }}</span>
        </div>
        <div class="field-row">
            <span class="label">Address:</span>
            <span class="value">{{ applicant_address }}</span>
        </div>
        <div class="field-row">
            <span class="label">Phone:</span>
            <span class="value">{{ applicant_phone }}</span>
        </div>
        <div class="field-row">
            <span class="label">Email:</span>
            <span class="value">{{ applicant_email }}</span>
        </div>
    </div>
    
    <div class="section">
        <div class="section-title">DATE OF APPLICATION:</div>
        <p>{{ date_of_application }}</p>
    </div>
    
    <div class="section">
        <div class="section-title">SUBJECT:</div>
        <p>APPLICATION FOR INFORMATION UNDER SECTION 4(1) OF THE RIGHT TO INFORMATION ACT, 2005</p>
    </div>
    
    <div class="section">
        <p>Dear Sir/Madam,</p>
        <p>I, <strong>{{ applicant_name }}</strong>, hereby request the following information under Section 4(1) of the Right to Information Act, 2005:</p>
    </div>
    
    <div class="section">
        <div class="section-title">SPECIFIC INFORMATION SOUGHT:</div>
        <p style="white-space: pre-wrap;">{{ information_sought }}</p>
    </div>
    
    <div class="section">
        <div class="section-title">PREFERRED MODE OF INFORMATION:</div>
        <p>{{ preferred_mode }}</p>
    </div>
    
    <div class="section">
        <div class="section-title">PAYMENT OF FEE:</div>
        <p>I enclose application fee of ₹10 (Rupees Ten Only) as required under RTI Rules, 2012.</p>
    </div>
    
    <div class="section">
        <div class="section-title">DECLARATION:</div>
        <p>I declare that the above information is true to the best of my knowledge and belief.</p>
    </div>
    
    <div class="signature-area">
        <div class="signature-box">
            <p><strong>Date:</strong></p>
            <p>{{ date_of_application }}</p>
        </div>
        <div class="signature-box">
            <div class="signature-line">
                {{ applicant_name }}
            </div>
            <p><strong>(Signature)</strong></p>
        </div>
    </div>
    
    <div class="disclaimer">
        <p><strong>⚠️ IMPORTANT DISCLAIMER:</strong></p>
        <p>This document has been generated based on the Right to Information Act, 2005. This is NOT legal advice. 
        The user is solely responsible for the accuracy and correctness of information provided. 
        We recommend reviewing this document before submission. 
        LegalSarathi and its creators assume no liability for consequences of using this document. 
        Use at your own risk.</p>
    </div>

</div>

</body>
</html>
