{# Affidavit Template - General Purpose - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Affidavit</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.9; margin: 40px; color: #222; }
        .header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 14px; margin-bottom: 24px; }
        .header h1 { font-size: 18px; font-weight: bold; text-transform: uppercase; }
        .court-block { text-align: center; font-size: 12px; margin-bottom: 20px; }
        .body-text { font-size: 12px; text-align: justify; margin: 10px 0; }
        .deponent-box { border: 1px solid #888; padding: 12px; font-size: 12px; background: #fafafa; margin: 16px 0; }
        .statements { margin-left: 20px; }
        .statements li { margin: 10px 0; font-size: 11px; }
        .verification-box { border: 1px solid #999; padding: 12px; margin: 20px 0; font-size: 11px; background: #f9f9f9; }
        .signature-row { display: flex; justify-content: space-between; margin-top: 50px; }
        .sig-block { width: 44%; text-align: center; }
        .sig-line { border-top: 1px solid #000; padding-top: 4px; font-size: 11px; margin-top: 40px; }
        .stamp-area { border: 2px dashed #888; padding: 20px; text-align: center; font-size: 11px; color: #777; margin: 20px 0; width: 140px; height: 140px; display: flex; align-items: center; justify-content: center; }
        .disclaimer { font-size: 9px; border: 1px solid #999; padding: 8px; background: #fffacd; margin-top: 24px; }
    </style>
</head>
<body>

<div class="header">
    <h1>Affidavit</h1>
</div>

{% if court_name %}
<div class="court-block">
    <p><strong>In the {{ court_name }}</strong></p>
    <p>{{ court_jurisdiction }}</p>
    {% if case_number %}<p>Case/Application No.: {{ case_number }}</p>{% endif %}
</div>
{% endif %}

<div class="deponent-box">
    <p><strong>I, {{ deponent_name }}</strong>, aged <strong>{{ deponent_age }}</strong> years,</p>
    <p>S/o D/o W/o: <strong>{{ deponent_parent_spouse }}</strong>,</p>
    <p>Occupation: {{ deponent_occupation }},</p>
    <p>Residing at: <strong>{{ deponent_address }}</strong>,</p>
    <p>do hereby solemnly affirm and state as follows:</p>
</div>

<div class="body-text">
    <ol class="statements">
        <li>That I am the deponent herein and am competent to swear this Affidavit.</li>
        <li>That the facts stated herein are within my personal knowledge and belief and are true and correct.</li>
        <li style="white-space: pre-wrap;">{{ affidavit_statement }}</li>
        {% if additional_statement %}
        <li style="white-space: pre-wrap;">{{ additional_statement }}</li>
        {% endif %}
        <li>That the deponent has not suppressed any material facts and the statements made herein are true to the best of my knowledge and belief.</li>
    </ol>
</div>

<div class="verification-box">
    <strong>VERIFICATION:</strong><br><br>
    I, <strong>{{ deponent_name }}</strong>, the deponent above named, do hereby verify that the contents of paragraphs 1 to {{ total_paras | default("5") }} above are true to my personal knowledge and nothing material has been concealed therefrom.<br><br>
    Verified at <strong>{{ verification_place }}</strong> on this <strong>{{ affidavit_date }}</strong>.
</div>

<div class="signature-row">
    <div class="sig-block">
        <div class="sig-line">
            {{ deponent_name }}<br>
            (Deponent)
        </div>
    </div>
    <div class="sig-block">
        <div class="stamp-area">
            Notary / Commissioner<br>
            Seal &amp; Signature<br>
            <small>(To be affixed on stamped paper)</small>
        </div>
    </div>
</div>

<p style="font-size:11px; margin-top:16px;">
    <strong>Before me:</strong> Notary Public / First Class Judicial Magistrate / Executive Magistrate<br>
    Name: _________________________<br>
    Registration No.: ________________<br>
    Date: {{ affidavit_date }}
</p>

<div class="disclaimer">
    <strong>⚠ DISCLAIMER:</strong> This affidavit must be sworn on Non-Judicial Stamp Paper of appropriate value (as per state rules — typically ₹20 or ₹50) before a Notary Public or First Class Magistrate.
    This template is NOT legal advice. The deponent is solely responsible for the truth of the contents.
    LegalSarthi assumes no liability for use of this template.
</div>

</body>
</html>
