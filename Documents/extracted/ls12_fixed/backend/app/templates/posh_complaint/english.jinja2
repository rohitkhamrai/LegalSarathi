{# POSH Complaint Template - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>POSH Complaint</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; margin: 40px; }
        .header { text-align: center; border-bottom: 2px solid black; padding-bottom: 15px; margin-bottom: 20px; }
        .section { margin: 20px 0; }
        .section-title { font-weight: bold; background: #f0f0f0; padding: 8px; margin-bottom: 10px; }
        p { margin: 5px 0; font-size: 11px; }
        .checkbox { margin: 3px 0; }
        .disclaimer { font-size: 9px; border: 1px solid #999; padding: 8px; background: #fffacd; margin-top: 20px; }
    </style>
</head>
<body>

<div class="header">
    <h1>FORMAL COMPLAINT OF SEXUAL HARASSMENT AT WORKPLACE</h1>
    <h2>Under the Sexual Harassment of Women at Workplace (Prevention, Prohibition and Redressal) Act, 2013</h2>
    <p>Date: {{ complaint_date }}</p>
</div>

<div class="section">
    <div class="section-title">TO: INTERNAL COMPLAINTS COMMITTEE / HR DEPARTMENT</div>
    <p>{{ company_name }}</p>
</div>

<div class="section">
    <div class="section-title">COMPLAINANT DETAILS:</div>
    <p><strong>Name:</strong> {{ complainant_name }}</p>
    <p><strong>Designation:</strong> {{ designation }}</p>
    <p><strong>Department:</strong> {{ department }}</p>
    <p><strong>Employee ID:</strong> {{ employee_id }}</p>
    <p><strong>Contact No.:</strong> {{ contact_no }}</p>
</div>

<div class="section">
    <div class="section-title">RESPONDENT DETAILS:</div>
    <p><strong>Name:</strong> {{ respondent_name }}</p>
    <p><strong>Designation:</strong> {{ respondent_designation }}</p>
    <p><strong>Department:</strong> {{ respondent_department }}</p>
</div>

<div class="section">
    <div class="section-title">NATURE OF HARASSMENT:</div>
    <div class="checkbox">☐ Unwelcome verbal conduct (jokes, comments, remarks)</div>
    <div class="checkbox">☐ Unwelcome physical contact (touching, assault)</div>
    <div class="checkbox">☐ Unwelcome sexual advances</div>
    <div class="checkbox">☐ Quid pro quo (favors for cooperation)</div>
    <div class="checkbox">☐ Hostile work environment</div>
</div>

<div class="section">
    <div class="section-title">DETAILED ACCOUNT OF HARASSMENT:</div>
    <p><strong>Date:</strong> {{ incident_date }}</p>
    <p><strong>Time:</strong> {{ incident_time }}</p>
    <p><strong>Location:</strong> {{ incident_location }}</p>
    <p><strong>Description:</strong></p>
    <p style="white-space: pre-wrap; margin-left: 20px;">{{ incident_description }}</p>
    <p><strong>Witnesses (if any):</strong> {{ witnesses }}</p>
</div>

<div class="section">
    <div class="section-title">IMPACT OF HARASSMENT:</div>
    <p><strong>Impact on work:</strong> {{ work_impact }}</p>
    <p><strong>Emotional/Psychological impact:</strong> {{ emotional_impact }}</p>
</div>

<div class="section">
    <div class="section-title">RELIEF SOUGHT:</div>
    <div class="checkbox">☐ Disciplinary action against respondent</div>
    <div class="checkbox">☐ Termination of respondent</div>
    <div class="checkbox">☐ Compensation for damages</div>
    <div class="checkbox">☐ Counseling support</div>
    <div class="checkbox">☐ Transfer of respondent</div>
</div>

<div class="section">
    <p><strong>I declare that the above information is true to the best of my knowledge.</strong></p>
    <p style="margin-top: 30px;">_____________________________</p>
    <p>{{ complainant_name }}</p>
    <p>Date: {{ complaint_date }}</p>
</div>

<div class="disclaimer">
    <p><strong>DISCLAIMER:</strong> This is a template based on POSH Act, 2013. This is not legal advice. 
    Your company MUST accept this complaint. If not received, escalate to External Committee. Please retain a copy for your records.</p>
</div>

</body>
</html>
