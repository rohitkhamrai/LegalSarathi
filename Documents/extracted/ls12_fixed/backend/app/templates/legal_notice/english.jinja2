{# Legal Notice Template - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Legal Notice</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.7; margin: 40px; color: #222; }
        .header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 14px; margin-bottom: 20px; }
        .header h1 { font-size: 17px; font-weight: bold; text-transform: uppercase; }
        .from-block, .to-block { font-size: 12px; margin-bottom: 14px; }
        .subject-line { font-size: 12px; font-weight: bold; margin: 16px 0; border-left: 4px solid #222; padding-left: 10px; }
        .body-text { font-size: 11px; text-align: justify; margin: 12px 0; line-height: 1.8; }
        .demand-list { margin-left: 24px; margin-top: 8px; }
        .demand-list li { margin: 6px 0; font-size: 11px; }
        .consequences { border: 1px solid #999; padding: 10px; background: #fff8f8; margin: 16px 0; font-size: 11px; }
        .signature-area { margin-top: 48px; }
        .sig-line { border-top: 1px solid #000; width: 220px; padding-top: 4px; font-size: 11px; margin-top: 36px; }
        .disclaimer { font-size: 9px; border: 1px solid #999; padding: 8px; background: #fffacd; margin-top: 24px; }
    </style>
</head>
<body>

<div class="header">
    <h1>Legal Notice</h1>
</div>

<div class="from-block">
    <p><strong>From:</strong></p>
    <p>{{ sender_name }}</p>
    <p>{{ sender_address }}</p>
    <p>Phone: {{ sender_phone }}</p>
    <p>Email: {{ sender_email }}</p>
</div>

<div class="to-block">
    <p><strong>To:</strong></p>
    <p>{{ recipient_name }}</p>
    <p>{{ recipient_designation | default("") }}</p>
    <p>{{ recipient_address }}</p>
</div>

<p style="font-size:12px;"><strong>Date: {{ notice_date }}</strong></p>

<div class="subject-line">
    Subject: Legal Notice — {{ notice_subject }}
</div>

<div class="body-text">
    <p>I, <strong>{{ sender_name }}</strong>, hereby serve upon you this legal notice through/on behalf of myself, as follows:</p>
</div>

<div class="body-text">
    <p><strong>1. Background and Facts:</strong></p>
    <p style="white-space: pre-wrap; margin-left:16px;">{{ background_facts }}</p>
</div>

<div class="body-text">
    <p><strong>2. Your Default / Breach:</strong></p>
    <p style="white-space: pre-wrap; margin-left:16px;">{{ breach_description }}</p>
</div>

<div class="body-text">
    <p><strong>3. Legal Basis:</strong></p>
    <p style="margin-left:16px;">{{ legal_provisions }}</p>
</div>

<div class="body-text">
    <p><strong>4. Demands:</strong></p>
    <p>I hereby demand that you:</p>
    <ol class="demand-list">
        <li>{{ demand_1 }}</li>
        {% if demand_2 %}<li>{{ demand_2 }}</li>{% endif %}
        {% if demand_3 %}<li>{{ demand_3 }}</li>{% endif %}
    </ol>
</div>

<div class="consequences">
    <strong>5. Consequences of Non-Compliance:</strong><br>
    Please take notice that if you fail to comply with the above demands within <strong>{{ compliance_days | default("15") }} days</strong> from the receipt of this notice, I shall be constrained to initiate appropriate legal proceedings against you before the competent court/authority, without further notice, at your risk and cost. All costs and consequences of such action shall be borne by you.
</div>

<div class="body-text">
    <p>This notice is being sent to you without prejudice to all other rights and remedies available to me under the law.</p>
</div>

<div class="signature-area">
    <p>Yours faithfully,</p>
    <div class="sig-line">
        {{ sender_name }}<br>
        (Sender / Noticee)
    </div>
    <p style="margin-top:16px; font-size:11px;">Date: {{ notice_date }}</p>
    <p style="font-size:11px;">Place: {{ sender_city }}</p>
</div>

<div class="disclaimer">
    <strong>⚠ DISCLAIMER:</strong> This legal notice template is for general use only. This is NOT legal advice.
    For the most effective legal notices — especially in property, money recovery, or defamation matters —
    please have this reviewed and sent through a registered advocate.
    LegalSarthi assumes no liability for use of this template.
</div>

</body>
</html>
