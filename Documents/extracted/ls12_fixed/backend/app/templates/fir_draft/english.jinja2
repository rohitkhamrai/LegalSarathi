{# FIR Draft / Police Complaint Template - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>FIR / Police Complaint Draft</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.7; margin: 40px; color: #222; }
        .header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 14px; margin-bottom: 20px; }
        .header h1 { font-size: 16px; font-weight: bold; }
        .header h2 { font-size: 12px; font-weight: normal; margin-top: 4px; }
        .to-block { margin-bottom: 20px; font-size: 12px; }
        .subject-line { font-size: 12px; font-weight: bold; margin: 16px 0; border-left: 4px solid #444; padding-left: 10px; }
        .section { margin: 16px 0; }
        .section-title { font-weight: bold; background: #f0f0f0; padding: 6px 10px; margin-bottom: 8px; font-size: 11px; text-transform: uppercase; }
        p { margin: 6px 0; font-size: 11px; line-height: 1.6; }
        table { width: 100%; border-collapse: collapse; font-size: 11px; margin: 8px 0; }
        td { padding: 6px 8px; border: 1px solid #ccc; vertical-align: top; }
        td:first-child { font-weight: bold; width: 35%; background: #fafafa; }
        .relief-list { margin-left: 24px; }
        .relief-list li { margin: 4px 0; font-size: 11px; }
        .signature-area { margin-top: 40px; }
        .sig-line { border-top: 1px solid #000; width: 200px; padding-top: 4px; font-size: 11px; margin-top: 32px; }
        .disclaimer { font-size: 9px; border: 1px solid #999; padding: 8px; background: #fffacd; margin-top: 24px; }
    </style>
</head>
<body>

<div class="header">
    <h1>COMPLAINT / FIRST INFORMATION REPORT DRAFT</h1>
    <h2>Under the Bharatiya Nagarik Suraksha Sanhita, 2023 (BNSS) | Bharatiya Nyaya Sanhita, 2023 (BNS)</h2>
</div>

<div class="to-block">
    <p>To,</p>
    <p>The Station House Officer (SHO),</p>
    <p>{{ police_station }},</p>
    <p>{{ station_district }}, {{ state }}</p>
</div>

<div class="subject-line">
    Subject: Complaint regarding {{ offence_type }} — Request for Registration of FIR
</div>

<div class="section">
    <p>Respected Sir/Madam,</p>
    <p>I, <strong>{{ complainant_name }}</strong>, wish to lodge the following complaint and request you to register an FIR under the Bharatiya Nagarik Suraksha Sanhita, 2023 and take immediate legal action against the accused.</p>
</div>

<div class="section">
    <div class="section-title">Details of the Complainant</div>
    <table>
        <tr><td>Name</td><td>{{ complainant_name }}</td></tr>
        <tr><td>Age</td><td>{{ complainant_age }} years</td></tr>
        <tr><td>S/o or D/o or W/o</td><td>{{ complainant_parent_spouse }}</td></tr>
        <tr><td>Address</td><td>{{ complainant_address }}</td></tr>
        <tr><td>Phone</td><td>{{ complainant_phone }}</td></tr>
        <tr><td>Email</td><td>{{ complainant_email }}</td></tr>
        <tr><td>Aadhaar (optional)</td><td>{{ complainant_aadhaar | default("Not provided") }}</td></tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Details of the Accused</div>
    <table>
        <tr><td>Name</td><td>{{ accused_name }}</td></tr>
        <tr><td>Address / Last Known</td><td>{{ accused_address }}</td></tr>
        <tr><td>Relationship to Complainant</td><td>{{ accused_relationship }}</td></tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Incident Details</div>
    <table>
        <tr><td>Date of Incident</td><td>{{ incident_date }}</td></tr>
        <tr><td>Time of Incident</td><td>{{ incident_time }}</td></tr>
        <tr><td>Place of Incident</td><td>{{ incident_location }}</td></tr>
        <tr><td>Nature of Offence</td><td>{{ offence_type }}</td></tr>
        <tr><td>BNS Sections Applicable</td><td>{{ bns_sections }}</td></tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Full Account of the Incident</div>
    <p style="white-space: pre-wrap;">{{ incident_description }}</p>
</div>

{% if witnesses %}
<div class="section">
    <div class="section-title">Witnesses</div>
    <p style="white-space: pre-wrap;">{{ witnesses }}</p>
</div>
{% endif %}

{% if evidence_available %}
<div class="section">
    <div class="section-title">Evidence / Documents Available</div>
    <p style="white-space: pre-wrap;">{{ evidence_available }}</p>
</div>
{% endif %}

<div class="section">
    <div class="section-title">Relief Sought</div>
    <p>In view of the above, I respectfully request you to:</p>
    <ol class="relief-list">
        <li>Register an FIR under the relevant sections of BNS 2023 against the accused;</li>
        <li>Investigate the matter thoroughly and take appropriate legal action;</li>
        <li>Ensure my safety and the safety of my family during the investigation;</li>
        <li>{{ additional_relief | default("Take such other action as deemed fit in the interests of justice.") }}</li>
    </ol>
</div>

<div class="section">
    <p>I declare that the above information is true and correct to the best of my knowledge. I am prepared to cooperate fully with the investigation.</p>
</div>

<div class="signature-area">
    <p>Date: {{ complaint_date }}</p>
    <p>Place: {{ complainant_city }}</p>
    <div class="sig-line">
        {{ complainant_name }}<br>
        (Complainant's Signature)
    </div>
</div>

<div class="disclaimer">
    <strong>⚠ DISCLAIMER:</strong> This is a draft complaint under BNS 2023 / BNSS 2023. This is NOT legal advice.
    You have the right to lodge a complaint at your nearest police station. If refused, you may approach the Superintendent of Police or a Magistrate directly under Section 175 of BNSS 2023.
    LegalSarthi assumes no liability for the use of this template.
</div>

</body>
</html>
