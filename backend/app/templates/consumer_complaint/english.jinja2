{# Consumer Complaint Template - English #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Consumer Complaint</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; margin: 40px; }
        .header { text-align: center; border-bottom: 2px solid black; padding-bottom: 15px; margin-bottom: 20px; }
        .section { margin: 20px 0; }
        .section-title { font-weight: bold; background: #f0f0f0; padding: 8px; margin-bottom: 10px; }
        p { margin: 5px 0; font-size: 11px; }
        .disclaimer { font-size: 9px; border: 1px solid #999; padding: 8px; background: #fffacd; margin-top: 20px; }
    </style>
</head>
<body>

<div class="header">
    <h1>CONSUMER COMPLAINT</h1>
    <h2>Under the Consumer Protection Act, 2019</h2>
    <p>Date: {{ complaint_date }}</p>
</div>

<div class="section">
    <div class="section-title">COMPLAINANT DETAILS:</div>
    <p><strong>Name:</strong> {{ complainant_name }}</p>
    <p><strong>Address:</strong> {{ complainant_address }}</p>
    <p><strong>Phone:</strong> {{ complainant_phone }}</p>
    <p><strong>Email:</strong> {{ complainant_email }}</p>
</div>

<div class="section">
    <div class="section-title">OPPOSITE PARTY (SELLER/SERVICE PROVIDER):</div>
    <p><strong>Name:</strong> {{ seller_name }}</p>
    <p><strong>Address:</strong> {{ seller_address }}</p>
    <p><strong>Phone:</strong> {{ seller_phone }}</p>
</div>

<div class="section">
    <div class="section-title">PRODUCT/SERVICE DETAILS:</div>
    <p><strong>Product/Service:</strong> {{ product_service }}</p>
    <p><strong>Date of Purchase:</strong> {{ purchase_date }}</p>
    <p><strong>Price Paid:</strong> ₹{{ amount_paid }}</p>
</div>

<div class="section">
    <div class="section-title">NATURE OF COMPLAINT:</div>
    <p style="white-space: pre-wrap;">{{ complaint_description }}</p>
</div>

<div class="section">
    <div class="section-title">RELIEF SOUGHT:</div>
    <p style="white-space: pre-wrap;">{{ relief_sought }}</p>
</div>

<div class="section">
    <p><strong>I declare that the above information is true to the best of my knowledge.</strong></p>
    <p style="margin-top: 30px;">_____________________________</p>
    <p>{{ complainant_name }}</p>
    <p>Date: {{ complaint_date }}</p>
</div>

<div class="disclaimer">
    <p><strong>DISCLAIMER:</strong> This is a template based on Consumer Protection Act, 2019. This is not legal advice. 
    Please consult a lawyer for specific guidance on your case.</p>
</div>

</body>
</html>
